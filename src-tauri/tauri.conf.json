{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orama",
  "version": "0.1.0",
  "identifier": "com.orama.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Orama",
        "width": 1440,
        "height": 960,
        "minWidth": 900,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "icon": [
      "icons/icon.icns"
    ]
  }
}
